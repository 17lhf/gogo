# 开发环境启动时自动加载此文件（APP_ENV=development 或未设置时）
# 生产环境设置 APP_ENV=production，直接读取系统环境变量

# PostgreSQL — Docker Compose 用于初始化容器 / Go 应用连接用
# Codespace/Docker 内运行时用服务名；本地直接运行时改为 localhost
POSTGRES_USER=gogo
POSTGRES_PASSWORD=gogo123
POSTGRES_DB=gogo_dev
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis
# Codespace/Docker 内运行时用服务名；本地直接运行时改为 localhost:6379
REDIS_ADDR=192.168.33.192:7480
REDIS_PASSWORD=riverGotoSee121

# Auth
JWT_SECRET=change-me-to-a-random-secret-in-production
AUTH_SESSION_TTL=8h
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_DURATION=30m
AUTH_PASSWORD_COST=12
AUTH_PASSWORD_MAX_AGE=8760h

# Logging
# LOG_LEVEL: debug | info | warn | error (default: info)
# LOG_FORMAT: json | text (default: json)
LOG_LEVEL=debug
LOG_FORMAT=json

# App
APP_ENV=development
APP_PORT=8080
