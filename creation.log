2026-05-08 06:56:05.553Z: name: gogo
services:
  app:
    command:
      - sleep
      - infinity
    depends_on:
      postgres:
        condition: service_healthy
        required: ********
      redis:
        condition: service_healthy
        required: ********
    environment:
      CODESPACES: "********"
    image: mcr.microsoft.com/devcontainers/go:1.26
    labels:
      ContainerVersion: "13"
      Type: codespaces
    networks:
      gogo-net: null
    volumes:
      - type: bind
        source: /var/lib/docker/codespacemount/workspace
        target: /workspaces/gogo
        bind: {}
      - type: bind
        source: /var/run/docker.sock
        target: /var/run/docker.sock
        bind: {}
      - type: bind
        source: /root/.codespaces/shared
        target: /workspaces/.codespaces/shared
        bind: {}
      - type: bind
        source: /var/lib/docker/codespacemount/.persistedshare
        target: /workspaces/.codespaces/.persistedshare
        bind: {}
      - type: bind
        source: /.codespaces/agent/mount
        target: /.codespaces/bin
        bind: {}
      - type: bind
        source: /mnt/containerTmp
        target: /tmp
        bind: {}
      - type: bind
        source: /var/lib/docker/codespacemount/workspace
        target: /workspaces
        bind: {}
  postgres:
    environment:
      POSTGRES_DB: ********
      POSTGRES_PASSWORD: ********
      POSTGRES_USER: gogo
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U gogo -d ********
      timeout: 5s
      interval: 5s
      retries: 10
    image: postgres:16-alpine
    networks:
      gogo-net: null
    ports:
      - mode: ingress
        host_ip: 127.0.0.1
        target: 5432
        published: "5432"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: postgres-data
        target: /var/lib/postgresql/data
        volume: {}
  redis:
    command:
      - redis-server
      - --appendonly
      - "yes"
    healthcheck:
      test:
        - CMD
        - redis-cli
        - ping
      timeout: 5s
      interval: 5s
      retries: 10
    image: redis:7-alpine
    networks:
      gogo-net: null
    ports:
      - mode: ingress
        host_ip: 127.0.0.1
        target: 6379
        published: "6379"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: redis-data
        target: /data
        volume: {}
networks:
  gogo-net:
    name: gogo_gogo-net
    driver: bridge
volumes:
  postgres-data:
    name: gogo_postgres-data
  redis-data:
    name: gogo_redis-data

